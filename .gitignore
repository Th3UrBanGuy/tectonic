# ============================================================================
# Techtonic — .gitignore
# Comprehensive protection against pushing sensitive data, build artifacts,
# dependencies, and unwanted files to any remote repository.
# ============================================================================

# ─── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
bun.lockb

# ─── Environment Variables (SECRETS — NEVER COMMIT) ────────────────────────
# Database credentials, JWT secrets, API keys — all live here.
# Use .env.example as the template; each developer sets their own .env.
.env
.env.*
!.env.example

# ─── Next.js Build Output ──────────────────────────────────────────────────
.next/
out/
build/
dist/

# ─── TypeScript ────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ───────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Debug Logs ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log
*.log

# ─── OS-Generated Files ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor / IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Vercel ────────────────────────────────────────────────────────────────
.vercel/

# ─── Docker (local overrides) ──────────────────────────────────────────────
docker-compose.override.yml

# ─── Database (local SQLite — should not exist, but just in case) ──────────
db/
*.db
*.db-journal
*.sqlite
*.sqlite3

# ─── Prisma (generated client — should not be committed) ───────────────────
# The Prisma client is generated by `prisma generate` (runs via postinstall).
# Don't commit it — it's platform-specific and auto-generated.
prisma/migrations/dev.db*

# ─── Upload Artifacts ──────────────────────────────────────────────────────
upload/
download/
tool-results/

# ─── AI / Development Worklog (contains credentials & internal notes) ──────
worklog.md
.claude/
.z-ai-config/
.zscripts/

# ─── Skills (Z.ai system — not part of the project) ────────────────────────
/skills/

# ─── Examples (demo code — not part of the production app) ─────────────────
/examples/

# ─── Mini-services (separate bun projects — not part of this repo) ─────────
/mini-services/

# ─── Misc ──────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx
prompt
test
local-*
